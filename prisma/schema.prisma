generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String
  createdAt DateTime @default(now()) @map("created_at")
  habits Habit[]
  moods MoodEntry[]
  journals Journal[]
  @@map("users")
}

model Habit {
  id Int @id @default(autoincrement())
  name String
  frequency String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int @map("user_id")
  moods MoodEntry[]
  @@map("habits")
}

model MoodEntry {
  id Int @id @default(autoincrement())
  mood String
  note String?
  date DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int @map("user_id")
  habit Habit? @relation(fields: [habitId], references: [id], onDelete: SetNull)
  habitId Int? @map("habit_id")
  @@map("mood_entries")
}

model Journal {
  id Int @id @default(autoincrement())
  title String
  content String
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int @map("user_id")
  @@map("journals")
}